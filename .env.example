# Build local / Vercel / GitHub backup workflow
NOTION_TOKEN=
NOTION_PUBLICATIONS_DATA_SOURCE_ID=
NOTION_AGENDA_DATA_SOURCE_ID=
NOTION_MENU_ITEMS_DATA_SOURCE_ID=
# Optional legacy source: section pages / JSON payloads
NOTION_SITE_SECTIONS_DATA_SOURCE_ID=
# Recommended: single source of truth for site sections
NOTION_SITE_SECTION_ITEMS_DATA_SOURCE_ID=
SITE_TIME_ZONE=Europe/Paris

# Webhook Vercel
NOTION_WEBHOOK_VERIFICATION_TOKEN=
VERCEL_DEPLOY_HOOK_URL=

# Production reconcile state + workflow dispatch
CONTENT_RECONCILE_DEBOUNCE_MINUTES=15
CONTENT_RECONCILE_STATE_ISSUE_NUMBER=
GITHUB_PRODUCTION_WORKFLOW_FILE=reconcile-prod-deploy.yml
GITHUB_PRODUCTION_WORKFLOW_REF=main

# GitHub workflow dispatch / issue state / optional GitHub Pages demo redeploy
GITHUB_WEBHOOK_TOKEN=
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY_NAME=
GITHUB_WORKFLOW_FILE=deploy-demo-pages.yml
GITHUB_WORKFLOW_REF=main
