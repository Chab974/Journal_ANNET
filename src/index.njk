---
permalink: index.html
---
{% set activePage = 'home' %}
{% set navSection = journal.siteSections['site-nav'] %}
{% set homePage = journal.siteSections['home-page'] %}
{% set homeHero = journal.siteSections['home-hero'] %}
{% set homeRubriques = journal.siteSections['home-rubriques'] %}
{% set footerSection = journal.siteSections['footer'] %}
{% set featuredPublication = journal.home.featuredPublication %}
{% set heroSpotlightItems = journal.home.heroSpotlightItems %}
{% set heroSpotlightMode = journal.home.heroSpotlightMode %}
{% set secondaryPublications = journal.home.secondaryPublications %}
{% set upcomingEvents = journal.home.upcomingEvents %}
{% set cantineEntry = journal.home.cantineEntry %}
{% set quickLinks = journal.home.quickLinks %}
{% set heroTitleLines = homeHero.titleLines or ['Le Journal', "d'Annet-sur-Marne"] %}
{% set pageTitle = homePage.pageTitle or (heroTitleLines | join(' ')) %}
{% set pageCssHref = 'assets/styles/page-home.css' %}
{% include "site-shell-head.njk" %}
{% include "site-shell-open.njk" %}
        <section class="hero-shell px-6 py-8 md:px-10 md:py-10">
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8 items-start">
                <div class="space-y-6">
                    <p class="eyebrow">
                        <span>{{ homeHero.feature.kicker or 'Infos utiles' }}</span>
                        <span aria-hidden="true">•</span>
                        <span>{{ homeHero.masthead[2] or 'Annet-sur-Marne' }}</span>
                    </p>
                    <div>
                        <h1 class="text-4xl md:text-6xl font-heading font-black uppercase leading-[0.94] tracking-tight">
                            {% for line in heroTitleLines %}
                            <span class="block">{{ line }}</span>
                            {% endfor %}
                        </h1>
                        <p class="mt-4 max-w-2xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                            {{ homeHero.quote or homeHero.feature.description or "Les actualités du village, l'agenda commun et les repères utiles au même endroit." }}
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <a href="portail.html" class="action-pill bg-vintage-red text-white shadow-lg shadow-orange-200/70">{{ homePage.heroPrimaryLabel or 'Actualités' }}</a>
                        <a href="agenda.html" class="action-pill bg-vintage-blue text-white shadow-lg shadow-sky-200/70">{{ homePage.heroAgendaLabel or 'Agenda' }}</a>
                        <a href="{{ cantineEntry.href if cantineEntry else 'portail.html?rubrique=Scolaire' }}" class="action-pill bg-vintage-green text-white shadow-lg shadow-lime-200/70">{{ homePage.heroCantineLabel or 'Cantine & familles' }}</a>
                        <a href="portail.html?rubrique=Coup%20de%20c%C5%93ur%20litt%C3%A9raire" class="action-pill action-pill--lecture text-white shadow-lg shadow-amber-200/70">{{ homePage.heroLectureLabel or 'Coup de cœur' }}</a>
                    </div>
                    <p class="text-sm font-semibold tracking-[0.08em] uppercase text-[color:var(--muted)]">
                        {{ homePage.heroHelper or 'Trois parcours immédiats pour trouver une info utile en moins de cinq secondes.' }}
                    </p>
                </div>

                <div class="paper-card p-6 md:p-8{% if heroSpotlightItems.length %} paper-card--event{% endif %}">
                    {% if heroSpotlightItems.length %}
                    <div{% if heroSpotlightItems.length > 1 %} data-hero-carousel{% endif %}>
                        {% for item in heroSpotlightItems %}
                        <section class="hero-spotlight-slide"{% if heroSpotlightItems.length > 1 and not loop.first %} hidden aria-hidden="true"{% endif %} data-hero-slide>
                            <p class="text-xs uppercase tracking-[0.2em] font-bold text-vintage-green mb-3">
                                {% if heroSpotlightMode == 'today' %}
                                {{ homePage.todaySpotlightLabel or "Actu du jour" }}
                                {% else %}
                                {{ homePage.nextEventLabel or 'Prochain rendez-vous' }}
                                {% endif %}
                            </p>
                            <h2 class="text-3xl font-heading font-black uppercase leading-tight">{{ item.title }}</h2>
                            <p class="mt-3 text-sm md:text-base leading-relaxed text-[color:var(--muted)]">{{ item.description }}</p>
                            <div class="mt-5 flex flex-wrap gap-3">
                                <span class="category-chip text-vintage-green">{{ item.date_label }}</span>
                                {% if item.time_label %}
                                <span class="category-chip text-ink">{{ item.time_label }}</span>
                                {% endif %}
                            </div>
                            {% if item.location %}
                            <p class="mt-4 text-sm font-semibold">Lieu : {{ item.location }}</p>
                            {% endif %}
                            <div class="mt-6 flex flex-wrap gap-3">
                                <a href="agenda.html" class="inline-flex items-center rounded-full bg-vintage-blue px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-lg shadow-sky-200/70">{{ homePage.viewAllAgendaLabel or "Voir tout l'agenda" }}</a>
                                <a href="{{ item.articleHref }}" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-5 py-3 text-xs font-bold uppercase tracking-[0.18em]">{{ homePage.viewArticleLabel or "Voir l'article" }}</a>
                            </div>
                        </section>
                        {% endfor %}
                        {% if heroSpotlightItems.length > 1 %}
                        <div class="hero-spotlight-controls">
                            <div class="hero-spotlight-nav">
                                <button type="button" class="hero-spotlight-arrow" data-hero-prev aria-label="Actu précédente">‹</button>
                                <button type="button" class="hero-spotlight-arrow" data-hero-next aria-label="Actu suivante">›</button>
                            </div>
                            <div class="hero-spotlight-dots">
                                {% for item in heroSpotlightItems %}
                                <button type="button" class="hero-spotlight-dot" data-hero-dot aria-label="Voir l'actu {{ loop.index }}"{% if loop.first %} aria-pressed="true"{% else %} aria-pressed="false"{% endif %}></button>
                                {% endfor %}
                            </div>
                            <span class="hero-spotlight-counter" data-hero-counter>1 / {{ heroSpotlightItems.length }}</span>
                        </div>
                        {% endif %}
                    </div>
                    {% elif featuredPublication %}
                    <p class="text-xs uppercase tracking-[0.2em] font-bold text-vintage-red mb-3">{{ homePage.featuredLabel or 'À la une' }}</p>
                    <h2 class="text-3xl font-heading font-black uppercase leading-tight">{{ featuredPublication.titre }}</h2>
                    <p class="mt-3 text-sm md:text-base leading-relaxed text-[color:var(--muted)]">{{ featuredPublication.resume }}</p>
                    <div class="mt-5 flex flex-wrap gap-3">
                        <span class="category-chip text-vintage-red">{{ featuredPublication.rubrique }}</span>
                        {% if featuredPublication.date %}
                        <span class="category-chip text-ink">{{ featuredPublication.date }}</span>
                        {% endif %}
                    </div>
                    <a href="{{ featuredPublication.href }}" class="mt-6 inline-flex items-center rounded-full bg-vintage-red px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-lg shadow-orange-200/70">{{ homePage.readArticleLabel or "Lire l'article" }}</a>
                    {% else %}
                    <p class="text-xs uppercase tracking-[0.2em] font-bold text-vintage-blue mb-3">{{ homePage.fallbackKicker or 'Accueil utile' }}</p>
                    <h2 class="text-3xl font-heading font-black uppercase leading-tight">{{ homePage.fallbackTitle or 'Toutes les infos locales au même endroit' }}</h2>
                    <p class="mt-3 text-sm md:text-base leading-relaxed text-[color:var(--muted)]">
                        {{ homePage.fallbackDescription or "Ouvre les actualités, consulte l'agenda ou retrouve les informations familles sans passer par une page manifeste longue." }}
                    </p>
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ homePage.spotlightKicker or 'En ce moment' }}</span>
                <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ homePage.spotlightTitle or "L'essentiel du village" }}</h2>
                        <p class="mt-3 max-w-3xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                            {{ homePage.spotlightDescription or 'Une carte principale pour le sujet à lire tout de suite, puis quelques raccourcis utiles pour continuer.' }}
                        </p>
                    </div>
                    <a href="portail.html" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-5 py-3 text-xs font-bold uppercase tracking-[0.18em]">{{ homePage.viewAllLabel or 'Voir toutes les actualités' }}</a>
                </div>
            </div>

            {% if featuredPublication or secondaryPublications.length %}
            <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6">
                <article class="paper-card p-6 md:p-8">
                    {% if featuredPublication %}
                    <div class="flex flex-wrap gap-3 mb-4">
                        <span class="category-chip text-vintage-red">{{ featuredPublication.typeLabel }}</span>
                        <span class="category-chip text-vintage-blue">{{ featuredPublication.rubrique }}</span>
                        {% if featuredPublication.date %}
                        <span class="category-chip text-ink">{{ featuredPublication.date }}</span>
                        {% endif %}
                    </div>
                    <h3 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ featuredPublication.titre }}</h3>
                    <p class="mt-4 text-base md:text-lg leading-relaxed text-[color:var(--muted)]">{{ featuredPublication.resume }}</p>
                    {% if featuredPublication.lieu %}
                    <p class="mt-4 text-sm font-semibold">Lieu : {{ featuredPublication.lieu }}</p>
                    {% endif %}
                    <div class="mt-6 flex flex-wrap gap-3">
                        <a href="{{ featuredPublication.href }}" class="inline-flex items-center rounded-full bg-vintage-red px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-lg shadow-orange-200/70">{{ homePage.readArticleLabel or "Lire l'article" }}</a>
                        <a href="{{ featuredPublication.rubriqueHref }}" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-5 py-3 text-xs font-bold uppercase tracking-[0.18em]">{{ homePage.viewRubriqueLabel or 'Voir la rubrique' }}</a>
                    </div>
                    {% else %}
                    <p class="text-xs uppercase tracking-[0.2em] font-bold text-vintage-red mb-3">{{ homePage.featuredLabel or 'À la une' }}</p>
                    <h3 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ homePage.featuredFallbackTitle or 'Sélection éditoriale' }}</h3>
                    <p class="mt-4 text-base md:text-lg leading-relaxed text-[color:var(--muted)]">{{ homePage.featuredFallbackDescription or "Les dernières publications s'affichent dans la colonne de droite. Un article peut être mis en avant ici lorsqu'une information mérite une place prioritaire." }}</p>
                    <div class="mt-6 flex flex-wrap gap-3">
                        <a href="portail.html" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-5 py-3 text-xs font-bold uppercase tracking-[0.18em]">{{ homePage.viewAllLabel or 'Voir toutes les actualités' }}</a>
                    </div>
                    {% endif %}
                </article>

                <div class="space-y-4">
                    {% for post in secondaryPublications %}
                    <article class="paper-card p-5">
                        <div class="flex flex-wrap gap-3 mb-3">
                            <span class="category-chip text-vintage-blue">{{ post.rubrique }}</span>
                            <span class="category-chip text-ink">{{ post.typeLabel }}</span>
                        </div>
                        <h3 class="text-2xl font-heading font-black leading-tight">{{ post.titre }}</h3>
                        <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">{{ post.resume }}</p>
                        <a href="{{ post.href }}" class="mt-4 inline-flex items-center text-sm font-bold uppercase tracking-[0.12em] text-vintage-blue">{{ homePage.openLabel or 'Ouvrir' }}</a>
                    </article>
                    {% endfor %}
                </div>
            </div>
            {% else %}
            <div class="paper-card p-8 text-center">
                <p class="font-heading font-bold uppercase tracking-widest text-sm">{{ homePage.emptyPublicationsTitle or "Aucune publication n'est disponible pour le moment." }}</p>
            </div>
            {% endif %}
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ homePage.weeklyKicker or 'Cette semaine' }}</span>
                <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ homePage.weeklyTitle or 'Agenda commun et repères familles' }}</h2>
                <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                    {{ homePage.weeklyDescription or "Les prochains événements d'un côté, la cantine de la semaine de l'autre, pour ne pas changer de page à chaque besoin." }}
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6">
                <div class="paper-card p-6 md:p-8">
                    <div class="flex items-center justify-between gap-4 mb-5">
                        <h3 class="text-2xl font-heading font-black uppercase">{{ homePage.upcomingTitle or 'Prochains événements' }}</h3>
                        <a href="agenda.html" class="text-sm font-bold uppercase tracking-[0.12em] text-vintage-blue">{{ homePage.upcomingLinkLabel or 'Agenda complet' }}</a>
                    </div>
                    {% if upcomingEvents.length %}
                    {% for eventItem in upcomingEvents %}
                    <article class="list-card rounded-2xl border border-ink/10 bg-white p-4">
                        <div class="flex flex-wrap gap-3 mb-2">
                            <span class="category-chip text-vintage-blue">{{ eventItem.rubrique }}</span>
                            <span class="category-chip text-ink">{{ eventItem.date_label }}</span>
                        </div>
                        <h4 class="text-xl font-heading font-black leading-tight">{{ eventItem.title }}</h4>
                        <p class="mt-2 text-sm leading-relaxed text-[color:var(--muted)]">{{ eventItem.description }}</p>
                        <div class="mt-3 flex flex-wrap gap-3 text-sm font-semibold">
                            {% if eventItem.time_label %}
                            <span>{{ eventItem.time_label }}</span>
                            {% endif %}
                            {% if eventItem.location %}
                            <span>{{ eventItem.location }}</span>
                            {% endif %}
                        </div>
                        <div class="mt-4 flex flex-wrap gap-3">
                            <a href="{{ eventItem.articleHref }}" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.12em]">{{ homePage.viewArticleLabel or "Voir l'article" }}</a>
                            <a href="agenda.html" class="inline-flex items-center rounded-full border border-ink/15 bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.12em]">{{ homePage.eventAgendaLabel or "Voir l'agenda" }}</a>
                        </div>
                    </article>
                    {% endfor %}
                    {% else %}
                    <div class="rounded-2xl border border-ink/10 bg-white p-5">
                        <p class="font-heading font-bold uppercase tracking-widest text-sm">{{ homePage.emptyUpcomingTitle or 'Aucune date disponible pour le moment.' }}</p>
                        <p class="mt-2 text-sm text-[color:var(--muted)]">{{ homePage.emptyUpcomingDescription or "L'agenda complet reste accessible dès qu'un événement est publié." }}</p>
                    </div>
                    {% endif %}
                </div>

                <div class="paper-card p-6 md:p-8">
                    <div class="flex items-center justify-between gap-4 mb-5">
                        <h3 class="text-2xl font-heading font-black uppercase">{{ homePage.cantineTitle or 'Cantine & familles' }}</h3>
                        <a href="{{ cantineEntry.href if cantineEntry else 'portail.html?rubrique=Scolaire' }}" class="text-sm font-bold uppercase tracking-[0.12em] text-vintage-red">{{ homePage.cantineLinkLabel or 'Ouvrir la rubrique' }}</a>
                    </div>
                    {% if cantineEntry %}
                    <p class="text-base leading-relaxed text-[color:var(--muted)]">
                        {{ (homePage.cantineIntroTemplate or '{title} rassemble les repères de la semaine pour la restauration scolaire.') | replace('{title}', cantineEntry.publication_title or '') }}
                    </p>
                    <div class="mt-5 flex flex-wrap gap-3">
                        <span class="category-chip text-vintage-green">{{ cantineEntry.days | length }} {{ homePage.cantineDaysLabel or 'jours' }}</span>
                        <span class="category-chip text-ink">{{ cantineEntry.totalItems }} plats</span>
                        {% if cantineEntry.specialTitle %}
                        <span class="category-chip text-vintage-red">{{ (homePage.cantineSpecialTemplate or '{day} : note spéciale') | replace('{day}', cantineEntry.specialTitle or '') }}</span>
                        {% endif %}
                    </div>
                    <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {% for day in cantineEntry.days %}
                        <div class="rounded-2xl border border-ink/10 bg-white px-4 py-3">
                            <p class="text-xs uppercase tracking-[0.16em] font-bold {% if day.isSpecial %}text-vintage-red{% else %}text-vintage-green{% endif %}">{{ day.day }}</p>
                            {% if day.isSpecial %}
                            <p class="mt-2 text-sm leading-relaxed text-[color:var(--muted)]">{{ day.message }}</p>
                            {% else %}
                            <p class="mt-2 text-sm leading-relaxed text-[color:var(--muted)]">
                                {% if day.itemsCount > 1 %}
                                {{ (homePage.cantineItemsPluralTemplate or '{count} plats annoncés.') | replace('{count}', day.itemsCount) }}
                                {% else %}
                                {{ (homePage.cantineItemsSingularTemplate or '{count} plat annoncé.') | replace('{count}', day.itemsCount) }}
                                {% endif %}
                            </p>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    <a href="{{ cantineEntry.href }}" class="mt-6 inline-flex items-center rounded-full bg-vintage-green px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-lg shadow-lime-200/70">{{ homePage.cantineDetailLabel or 'Voir le détail cantine' }}</a>
                    {% else %}
                    <div class="rounded-2xl border border-ink/10 bg-white p-5">
                        <p class="font-heading font-bold uppercase tracking-widest text-sm">{{ homePage.emptyCantineTitle or 'Aucune publication cantine disponible.' }}</p>
                        <p class="mt-2 text-sm text-[color:var(--muted)]">{{ homePage.emptyCantineDescription or 'La rubrique scolaire reste accessible pour les informations familles.' }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ homePage.quickLinksKicker or 'Accès rapide' }}</span>
                <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ homePage.quickLinksTitle or 'Retrouver une rubrique en un clic' }}</h2>
                <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                    {{ homeRubriques.description or "Chaque rubrique ouvre directement le portail sur le bon filtre, avec le premier article publié quand il existe." }}
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                {% for link in quickLinks %}
                <a href="{{ link.href }}" class="paper-card quick-link-card {{ link.accentClass }} p-5 transition-transform hover:-translate-y-0.5">
                    <p class="text-xs uppercase tracking-[0.18em] font-bold quick-link-chip {{ link.chipClass }} mb-2">{{ link.rubrique }}</p>
                    <h3 class="text-2xl font-heading font-black leading-tight">{{ link.headline }}</h3>
                    <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">{{ link.description }}</p>
                    <p class="mt-4 text-xs font-bold uppercase tracking-[0.12em] {% if link.hasContent %}{{ link.chipClass }}{% else %}text-[color:var(--muted)]{% endif %}">
                        {% if link.hasContent %}{{ homePage.quickLinksOpenLabel or 'Ouvrir la rubrique' }}{% else %}{{ homePage.quickLinksEmptyLabel or 'Rubrique prête à accueillir du contenu' }}{% endif %}
                    </p>
                </a>
                {% endfor %}
            </div>
        </section>
{% include "site-shell-close.njk" %}
    <script src="assets/scripts/page-home.js"></script>
</body>
</html>
