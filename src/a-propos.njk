---
permalink: a-propos.html
---
{% set activePage = 'about' %}
{% set navSection = journal.siteSections['site-nav'] %}
{% set aboutPage = journal.siteSections['about-page'] %}
{% set homeHero = journal.siteSections['home-hero'] %}
{% set homeDiffusion = journal.siteSections['home-diffusion'] %}
{% set footerSection = journal.siteSections['footer'] %}
{% set firstPillar = aboutPage.pillars[0] %}
<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="{{ journal.site.pathPrefix }}">
    <title>{{ aboutPage.pageTitle or 'À propos' }} - {{ navSection.browserTitleSuffix or "Le Journal d'Annet-sur-Marne" }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
    <script id="about-copy-data" type="application/json">{{ aboutPage | inlineJson | safe }}</script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        body: ['Manrope', 'sans-serif'],
                        heading: ['Sora', 'sans-serif'],
                    },
                    colors: {
                        ink: '#16314a',
                        'vintage-red': '#f6a318',
                        'vintage-green': '#7fbf25',
                        'vintage-blue': '#2894e3'
                    }
                }
            }
        };
    </script>
    <style>
        :root {
            --paper: #f7faf7;
            --paper-strong: #ffffff;
            --ink: #16314a;
            --muted: #536679;
            --vintage-red: #f6a318;
            --vintage-green: #7fbf25;
            --vintage-blue: #2894e3;
            --line: #d9e5ec;
            --shadow-soft: 0 18px 48px rgba(31, 31, 28, 0.06);
            --shadow-card: 0 12px 26px rgba(31, 31, 28, 0.06);
        }
        body {
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(246,163,24,0.10), transparent 22%),
                radial-gradient(circle at top right, rgba(40,148,227,0.10), transparent 18%),
                linear-gradient(180deg, #fbfdfb 0%, #f2f8fb 100%);
        }
        .skip-link {
            position: absolute;
            left: 1rem;
            top: -3rem;
            z-index: 80;
            padding: 0.7rem 1rem;
            border-radius: 999px;
            background: var(--ink);
            color: #fff;
            font-weight: 700;
        }
        .skip-link:focus {
            top: 1rem;
        }
        .glass-nav {
            background:
                linear-gradient(180deg, rgba(255,255,255,0.96), rgba(249,252,252,0.92)),
                linear-gradient(90deg, rgba(246,163,24,0.10), rgba(127,191,37,0.08), rgba(40,148,227,0.10));
            backdrop-filter: blur(14px);
            box-shadow: 0 10px 24px rgba(22, 49, 74, 0.07);
        }
        .nav-link {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            --nav-soft: rgba(22, 49, 74, 0.05);
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0.72rem 1rem;
            border: 1px solid transparent;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.78);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.08);
            opacity: 1;
            color: var(--muted);
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            left: 0.85rem;
            right: 0.85rem;
            bottom: 0.46rem;
            height: 3px;
            border-radius: 999px;
            background: var(--nav-gradient);
            transform: scaleX(0);
            transform-origin: center;
            transition: transform 0.25s ease;
        }
        .nav-link--home {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), #ffbf52);
            --nav-soft: rgba(246, 163, 24, 0.14);
        }
        .nav-link--actualites {
            --nav-gradient: linear-gradient(135deg, var(--vintage-blue), #1f78d1);
            --nav-soft: rgba(40, 148, 227, 0.14);
        }
        .nav-link--lecture {
            --nav-gradient: linear-gradient(135deg, #7c3f2c, #b66b4c);
            --nav-soft: rgba(124, 63, 44, 0.14);
        }
        .nav-link--agenda {
            --nav-gradient: linear-gradient(135deg, var(--vintage-green), #5ea51a);
            --nav-soft: rgba(127, 191, 37, 0.16);
        }
        .nav-link--about {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            --nav-soft: rgba(246, 163, 24, 0.12);
        }
        .nav-link:hover,
        .nav-link.is-active {
            opacity: 1;
        }
        .nav-link:hover::after,
        .nav-link.is-active::after {
            transform: scaleX(1);
        }
        .nav-link:hover {
            color: var(--ink);
            background: var(--nav-soft);
            transform: translateY(-1px);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.08), 0 10px 18px rgba(22, 49, 74, 0.08);
        }
        .nav-link.is-active {
            color: #fff;
            background: var(--nav-gradient);
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .nav-link.is-active::after {
            background: rgba(255, 255, 255, 0.78);
        }
        .nav-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.08);
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(249,246,242,0.95));
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: var(--ink);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.06);
        }
        .nav-toggle[aria-expanded="true"] {
            color: #fff;
            border-color: transparent;
            background: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .mobile-nav-panel {
            padding: 0.75rem 0 1rem;
            border-top: 1px solid var(--line);
        }
        .mobile-nav-link {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 0.55rem;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.08);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.94);
            font-family: 'Sora', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--ink);
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
        }
        .mobile-nav-link::before {
            content: '';
            flex: 0 0 auto;
            width: 0.72rem;
            height: 0.72rem;
            border-radius: 999px;
            background: var(--nav-gradient);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
        }
        .mobile-nav-link--home {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), #ffbf52);
        }
        .mobile-nav-link--actualites {
            --nav-gradient: linear-gradient(135deg, var(--vintage-blue), #1f78d1);
        }
        .mobile-nav-link--lecture {
            --nav-gradient: linear-gradient(135deg, #7c3f2c, #b66b4c);
        }
        .mobile-nav-link--agenda {
            --nav-gradient: linear-gradient(135deg, var(--vintage-green), #5ea51a);
        }
        .mobile-nav-link--about {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
        }
        .mobile-nav-link:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(22, 49, 74, 0.08);
        }
        .mobile-nav-link.is-active {
            color: #fff;
            border-color: transparent;
            background: var(--nav-gradient);
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .mobile-nav-link.is-active::before {
            background: rgba(255, 255, 255, 0.88);
            box-shadow: none;
        }
        .hero-shell {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--line);
            border-radius: 28px;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,244,239,0.98)),
                radial-gradient(circle at 88% 16%, rgba(246,163,24,0.14), transparent 20%),
                radial-gradient(circle at 18% 82%, rgba(40,148,227,0.16), transparent 20%);
            box-shadow: var(--shadow-soft);
        }
        .section-shell {
            position: relative;
            overflow: hidden;
            padding: 1.4rem;
            border: 1px solid var(--line);
            border-radius: 18px;
            background: rgba(255,255,255,0.94);
            box-shadow: var(--shadow-card);
        }
        @media (min-width: 768px) {
            .section-shell {
                padding: 1.75rem;
            }
        }
        .section-shell::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.34), transparent 14%);
            pointer-events: none;
        }
        .section-header {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
            margin-bottom: 1.8rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--line);
        }
        .section-kicker {
            font-size: 0.72rem;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--vintage-blue);
        }
        .paper-card {
            border: 1px solid var(--line);
            border-radius: 18px;
            background: rgba(255,255,255,0.96);
            box-shadow: 0 10px 20px rgba(31, 31, 28, 0.05);
        }
        .category-chip {
            display: inline-flex;
            align-items: center;
            padding: 0.28rem 0.75rem;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255,255,255,0.94);
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }
        .fade-in {
            animation: fadeIn 0.45s ease-out;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body class="font-body antialiased text-ink">
    <a href="#main-content" class="skip-link">{{ navSection.skipLinkLabel or 'Aller au contenu' }}</a>
    {% include "site-nav.njk" %}

    <main id="main-content" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12 space-y-10 md:space-y-12">
        <section class="hero-shell px-6 py-8 md:px-10 md:py-10">
            <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8 items-start">
                <div>
                    <p class="text-xs uppercase tracking-[0.22em] font-bold text-[color:var(--muted)] mb-4">{{ aboutPage.kicker or 'À propos du projet' }}</p>
                    <h1 class="text-4xl md:text-6xl font-heading font-black uppercase leading-[0.94] tracking-tight">{{ aboutPage.title or 'Une édition locale claire, utile et constructive' }}</h1>
                    <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                        {{ aboutPage.description or "Cette page rassemble la vision éditoriale, la méthode de publication, la maquette du premier numéro et la stratégie de diffusion du Journal d'Annet." }}
                    </p>
                </div>
                <div class="paper-card p-6 md:p-8">
                    <p class="text-xs uppercase tracking-[0.2em] font-bold text-vintage-red mb-3">{{ aboutPage.heroSideLabel or 'Promesse éditoriale' }}</p>
                    <h2 class="text-3xl font-heading font-black uppercase leading-tight">{{ homeHero.editorial.title }}</h2>
                    <p class="mt-4 text-sm md:text-base leading-relaxed text-[color:var(--muted)]">
                        {{ homeHero.editorial.description }}
                    </p>
                    <div class="mt-5 flex flex-wrap gap-3">
                        {% for label in homeHero.masthead %}
                        <span class="category-chip text-vintage-blue">{{ label }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ aboutPage.visionKicker or 'Vision éditoriale' }}</span>
                <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ aboutPage.visionTitle or 'Pourquoi ce journal existe' }}</h2>
                <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                    {{ aboutPage.visionDescription or "Le projet part d'une volonté simple : informer sérieusement sur la vie du village, relier les habitants et éviter les polémiques inutiles." }}
                </p>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6">
                <div class="paper-card p-6 md:p-8">
                    <p class="text-xs uppercase tracking-[0.18em] font-bold text-vintage-red mb-3">{{ aboutPage.originLabel or 'Le point de départ' }}</p>
                    <p class="leading-relaxed text-base md:text-lg text-[color:var(--muted)]">
                        {{ aboutPage.originBody or "La dynamique citoyenne née à Annet-sur-Marne a montré un besoin d'information locale mieux structurée, plus pédagogique et plus calme. Le journal cherche à rendre les décisions, les initiatives et les rendez-vous compréhensibles sans filtre partisan." }}
                    </p>
                    <blockquote class="mt-6 rounded-3xl border border-ink/10 bg-white p-5 font-heading text-lg leading-snug">
                        {{ aboutPage.visionQuote or "Refuser la polémique et les attaques inutiles pour privilégier la compréhension des enjeux locaux, l'entraide et l'imagination d'un avenir commun." }}
                    </blockquote>
                </div>
                <div class="paper-card p-6 md:p-8">
                    <p class="text-xs uppercase tracking-[0.18em] font-bold text-vintage-blue mb-3">{{ aboutPage.homeFocusLabel or "Ce que la page d'accueil ne porte plus" }}</p>
                    <p class="text-sm md:text-base leading-relaxed text-[color:var(--muted)]">
                        {{ aboutPage.homeFocusBody or "La home se concentre désormais sur l'accès rapide aux contenus utiles. Le récit éditorial, la méthode et la maquette sont regroupés ici pour garder une page d'accueil plus courte et plus utile." }}
                    </p>
                </div>
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header text-center items-center">
                <span class="section-kicker">{{ aboutPage.pillarsKicker or 'Architecture éditoriale' }}</span>
                <h2 class="text-4xl font-heading font-black uppercase tracking-wider">{{ aboutPage.pillarsTitle or 'Nos 7 piliers éditoriaux' }}</h2>
                <p class="max-w-2xl mx-auto italic text-[color:var(--muted)]">
                    {{ aboutPage.pillarsDescription or "Découvrez l'ADN du journal en parcourant les piliers ci-dessous." }}
                </p>
            </div>
            <div class="flex flex-wrap justify-center gap-2 mb-8" id="pillar-buttons">
                <button type="button" class="px-4 py-3 mx-1 font-heading font-bold uppercase text-sm tracking-wider border rounded-full transition-all border-ink/20 shadow-lg shadow-black/10 backdrop-blur-sm" style="background: rgba(22, 49, 74, 0.88); color: rgba(255, 255, 255, 0.96);" aria-pressed="true">
                    {{ firstPillar.title or 'Info & Politique Locale' }}
                </button>
            </div>

            <div id="pillar-content" class="paper-card p-8 md:p-12 min-h-[220px] flex items-center justify-center fade-in">
                <div class="w-full max-w-4xl fade-in flex flex-col md:flex-row gap-8 items-center">
                    <div class="text-6xl md:text-8xl grayscale opacity-80">⚖️</div>
                    <div class="flex-1 space-y-4">
                        <h3 class="text-3xl font-heading font-black uppercase text-ink mb-2 border-b-2 border-vintage-red pb-2 inline-block">{{ firstPillar.title or 'Info & Politique Locale' }}</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
                            <div>
                                <h4 class="font-heading font-bold uppercase tracking-widest text-xs mb-1">{{ aboutPage.principleLabel or 'Le Principe' }}</h4>
                                <p class="text-sm leading-relaxed text-justify">{{ firstPillar.principle or 'Rendre compte des décisions municipales et intercommunales de manière neutre, pédagogique et sourcée.' }}</p>
                            </div>
                            <div>
                                <h4 class="font-heading font-bold uppercase tracking-widest text-xs mb-1">{{ aboutPage.objectiveLabel or "L'Objectif" }}</h4>
                                <p class="text-sm leading-relaxed text-justify font-bold">{{ firstPillar.objective or 'Permettre à chaque citoyen de comprendre les enjeux sans filtre partisan ou animosité.' }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ aboutPage.prototypeKicker or 'Prototype éditorial' }}</span>
                <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ aboutPage.prototypeTitle or 'La maquette du premier numéro' }}</h2>
                <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                    {{ aboutPage.prototypeDescription or 'La maquette papier sert de référence narrative : un édito, des décryptages, un guide citoyen et une partie plus participative.' }}
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {% for card in aboutPage.mockupPages %}
                <article class="paper-card p-5">
                    <p class="text-xs uppercase tracking-[0.18em] font-bold {% if loop.index == 1 or loop.index == 4 %}text-vintage-red{% elif loop.index == 2 %}text-vintage-blue{% else %}text-vintage-green{% endif %} mb-2">{{ card.kicker }}</p>
                    <h3 class="text-2xl font-heading font-black">{{ card.title }}</h3>
                    <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">{{ card.description }}</p>
                </article>
                {% endfor %}
            </div>
        </section>

        <section class="section-shell">
            <div class="section-header">
                <span class="section-kicker">{{ homeDiffusion.kicker }}</span>
                <h2 class="text-3xl md:text-4xl font-heading font-black uppercase tracking-tight">{{ homeDiffusion.title }}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {% for card in homeDiffusion.cards %}
                <article class="paper-card p-6 text-center">
                    <div class="text-4xl mb-4">{{ card.emoji }}</div>
                    <h3 class="text-xl font-heading font-black uppercase mb-3">{{ card.title }}</h3>
                    <p class="text-sm leading-relaxed text-[color:var(--muted)]">{{ card.description }}</p>
                </article>
                {% endfor %}
            </div>
        </section>
    </main>

    {% include "site-footer.njk" %}

    <script>
        const aboutCopy = JSON.parse(document.getElementById('about-copy-data')?.textContent || '{}');
        const pillarsData = aboutCopy.pillars || [];
        const pillarVisuals = {
            p1: { icon: '⚖️', theme: 'vintage-red' },
            p2: { icon: '🤝', theme: 'vintage-red' },
            p3: { icon: '🛡️', theme: 'vintage-red' },
            p4: { icon: '☕', theme: 'vintage-red' },
            p5: { icon: '🌱', theme: 'vintage-green' },
            p6: { icon: '🎗️', theme: 'vintage-blue' },
            p7: { icon: '🛍️', theme: 'vintage-blue' }
        };

        const btnContainer = document.getElementById('pillar-buttons');
        const contentContainer = document.getElementById('pillar-content');
        let currentPillarId = pillarsData[0]?.id || 'p1';

        function renderPillars() {
            btnContainer.innerHTML = '';
            pillarsData.forEach((pillar) => {
                const isActive = pillar.id === currentPillarId;
                const button = document.createElement('button');
                button.type = 'button';
                button.className = `px-4 py-3 mx-1 font-heading font-bold uppercase text-sm tracking-wider border rounded-full transition-all ${isActive ? 'border-ink/20 shadow-lg shadow-black/10 backdrop-blur-sm' : 'border-ink/10 bg-white/70 text-ink hover:bg-white hover:-translate-y-0.5'}`;
                button.style.background = isActive ? 'rgba(22, 49, 74, 0.88)' : '';
                button.style.color = isActive ? 'rgba(255, 255, 255, 0.96)' : '';
                button.textContent = pillar.title;
                button.setAttribute('aria-pressed', String(isActive));
                button.onclick = () => {
                    currentPillarId = pillar.id;
                    renderPillars();
                    renderPillarContent();
                };
                btnContainer.appendChild(button);
            });
        }

        function renderPillarContent() {
            const pillar = pillarsData.find((item) => item.id === currentPillarId);
            if (!pillar) {
                return;
            }
            const visuals = pillarVisuals[pillar.id] || { icon: '✦', theme: 'vintage-red' };
            const titleColor = visuals.theme === 'vintage-red' ? 'text-ink' : `text-${visuals.theme}`;
            const accentLine = `border-${visuals.theme}`;

            contentContainer.innerHTML = `
                <div class="w-full max-w-4xl fade-in flex flex-col md:flex-row gap-8 items-center">
                    <div class="text-6xl md:text-8xl grayscale opacity-80">${visuals.icon}</div>
                    <div class="flex-1 space-y-4">
                        <h3 class="text-3xl font-heading font-black uppercase ${titleColor} mb-2 border-b-2 ${accentLine} pb-2 inline-block">${pillar.title}</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
                            <div>
                                <h4 class="font-heading font-bold uppercase tracking-widest text-xs mb-1">${aboutCopy.principleLabel || 'Le Principe'}</h4>
                                <p class="text-sm leading-relaxed text-justify">${pillar.principle}</p>
                            </div>
                            <div>
                                <h4 class="font-heading font-bold uppercase tracking-widest text-xs mb-1">${aboutCopy.objectiveLabel || "L'Objectif"}</h4>
                                <p class="text-sm leading-relaxed text-justify font-bold">${pillar.objective}</p>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        renderPillars();
        renderPillarContent();
    </script>
</body>
</html>
