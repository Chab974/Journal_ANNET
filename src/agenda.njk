---
permalink: agenda.html
---
{% set activePage = 'agenda' %}
{% set navSection = journal.siteSections['site-nav'] %}
{% set agendaPage = journal.siteSections['agenda-page'] %}
{% set footerSection = journal.siteSections['footer'] %}
{% set pageTitle = (agendaPage.pageTitle or agendaPage.title or 'Agenda') + ' - ' + (navSection.browserTitleSuffix or "Le Journal d'Annet-sur-Marne") %}
{% set pageCssHref = 'assets/styles/page-agenda.css' %}
{% include "site-shell-head.njk" %}
{% include "site-shell-open.njk" %}
        <section class="section-shell">
            <div class="section-header">
                <p class="section-kicker">{{ agendaPage.kicker or 'Calendrier commun' }}</p>
                <h1 class="text-4xl md:text-5xl font-heading font-black uppercase tracking-tight">{{ agendaPage.title or 'Agenda du village' }}</h1>
                <p class="max-w-4xl text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                    {{ agendaPage.description or 'Toutes les dates utiles au même endroit, avec filtres par rubrique et accès direct à l’article concerné.' }}
                </p>
            </div>

            <div class="agenda-toolbar">
                <div class="agenda-toolbar-main">
                    <input id="agenda-search" class="agenda-search" type="search" placeholder="{{ agendaPage.searchPlaceholder or 'Rechercher un événement, une rubrique ou un lieu...' }}" />
                </div>
                <div class="agenda-toolbar-side">
                    <div id="agenda-count" class="agenda-count">0 {{ agendaPage.countSingular or 'date' }}</div>
                    <div class="agenda-view-switch" aria-label="{{ agendaPage.viewSwitchLabel or "Choisir la vue de l'agenda" }}">
                        <button type="button" class="agenda-view-button" data-view="list" aria-pressed="true">{{ agendaPage.viewListLabel or 'Vue liste' }}</button>
                        <button type="button" class="agenda-view-button" data-view="calendar" aria-pressed="false">{{ agendaPage.viewCalendarLabel or 'Vue calendrier' }}</button>
                    </div>
                </div>
                <div id="agenda-filters" class="agenda-filters"></div>
            </div>

            <div id="agenda-status" class="hidden"></div>
            <div id="agenda-results">
                <div class="agenda-empty">
                    <p class="font-heading font-bold uppercase tracking-widest text-sm">{{ agendaPage.loadingTitle or 'Chargement des dates...' }}</p>
                </div>
            </div>
        </section>
{% include "site-shell-close.njk" %}
    <script src="assets/scripts/page-agenda.js"></script>
</body>
</html>
