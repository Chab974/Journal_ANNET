---
permalink: portail.html
---
{% set activePage = 'actualites' %}
{% set navSection = journal.siteSections['site-nav'] %}
{% set portalPage = journal.siteSections['portal-page'] %}
{% set footerSection = journal.siteSections['footer'] %}
{% set pageTitle = (portalPage.pageTitle or portalPage.title or 'Actualités') + ' - ' + (navSection.browserTitleSuffix or "Le Journal d'Annet-sur-Marne") %}
{% set pageCssHref = 'assets/styles/page-portal.css' %}
{% include "site-shell-head.njk" %}
{% include "site-shell-open.njk" %}
        <section class="section-shell">
            <div class="p-1 md:p-2">
                <div class="section-header">
                    <div class="max-w-4xl">
                        <p id="portal-page-kicker" class="section-kicker mb-3">{{ portalPage.kicker or 'Actualités locales filtrables' }}</p>
                        <h1 id="portal-page-title" class="text-4xl md:text-5xl font-heading font-black uppercase tracking-tight mb-3">{{ portalPage.title or 'Actualités' }}</h1>
                        <p id="portal-page-description" class="text-base md:text-lg leading-relaxed text-[color:var(--muted)]">
                            {{ portalPage.description or 'Une lecture claire de la vie locale : événements, scolaire, travaux, vie associative et coups de cœur réunis dans une même page, avec filtres par rubrique et accès direct aux articles.' }}
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <a href="agenda.html" class="inline-flex items-center gap-2 rounded-full bg-vintage-blue px-5 py-3 text-white text-xs font-bold uppercase tracking-[0.2em] shadow-lg shadow-sky-200/60 transition-transform hover:-translate-y-0.5">
                            <span aria-hidden="true">🗓️</span>
                            <span>{{ portalPage.agendaCtaLabel or "Voir l'agenda commun" }}</span>
                        </a>
                    </div>
                </div>

                <div class="portal-toolbar">
                    <div class="portal-toolbar-main">
                        <input id="portal-search" class="portal-search" type="search" placeholder="{{ portalPage.searchPlaceholder or 'Rechercher un titre, une rubrique, un lieu, un auteur...' }}" />
                    </div>
                    <div id="portal-count" class="portal-count">0 {{ portalPage.countSingular or 'publication' }}</div>
                    <div id="portal-filters" class="portal-filters"></div>
                </div>

                <div id="portal-status" class="hidden"></div>
                <div id="portal-posts" class="space-y-8">
                    <div class="paper-card p-8 text-center">
                        <p class="font-heading font-bold uppercase tracking-widest text-sm">{{ portalPage.loadingTitle or 'Chargement des publications...' }}</p>
                    </div>
                </div>
            </div>
        </section>
{% include "site-shell-close.njk" %}
    <script src="assets/scripts/page-portal.js"></script>
</body>
</html>
