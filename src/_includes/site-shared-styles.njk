        :root {
            --paper: #f7faf7;
            --paper-strong: #ffffff;
            --ink: #16314a;
            --muted: #536679;
            --vintage-red: #f6a318;
            --vintage-green: #7fbf25;
            --vintage-blue: #2894e3;
            --line: #d9e5ec;
            --shadow-soft: 0 18px 48px rgba(31, 31, 28, 0.06);
            --shadow-card: 0 12px 26px rgba(31, 31, 28, 0.06);
            --radius-xl: 18px;
        }
        body {
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(246,163,24,0.10), transparent 22%),
                radial-gradient(circle at top right, rgba(40,148,227,0.10), transparent 18%),
                linear-gradient(180deg, #fbfdfb 0%, #f2f8fb 100%);
        }
        .site-shell {
            max-width: 88rem;
            margin-inline: auto;
        }
        img {
            display: block;
            max-width: 100%;
            height: auto;
        }
        .skip-link {
            position: absolute;
            left: 1rem;
            top: -3rem;
            z-index: 80;
            padding: 0.7rem 1rem;
            border-radius: 999px;
            background: var(--ink);
            color: #fff;
            font-weight: 700;
        }
        .skip-link:focus {
            top: 1rem;
        }
        .glass-nav {
            background:
                linear-gradient(180deg, rgba(255,255,255,0.96), rgba(249,252,252,0.92)),
                linear-gradient(90deg, rgba(246,163,24,0.10), rgba(127,191,37,0.08), rgba(40,148,227,0.10));
            backdrop-filter: blur(14px);
            box-shadow: 0 10px 24px rgba(22, 49, 74, 0.07);
        }
        .nav-desktop-shell {
            min-width: 0;
        }
        .nav-desktop-links {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 1rem;
            flex-wrap: wrap;
        }
        @media (min-width: 1280px) {
            .nav-desktop-links {
                gap: 1.5rem;
            }
        }
        .nav-link {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            --nav-soft: rgba(22, 49, 74, 0.05);
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0.72rem 1rem;
            border: 1px solid transparent;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.78);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.08);
            opacity: 1;
            color: var(--muted);
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
        }
        .nav-search {
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }
        .nav-search--desktop {
            width: 100%;
            margin-top: 0.8rem;
        }
        .nav-search-label {
            flex: 0 0 auto;
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--vintage-green);
            white-space: nowrap;
        }
        .nav-search-input {
            flex: 1 1 auto;
            min-width: 0;
            min-height: 44px;
            padding: 0.8rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.12);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.95);
            color: var(--ink);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
            outline: none;
        }
        .nav-search-input::placeholder {
            color: #7b8a9a;
        }
        .nav-search-input:focus {
            border-color: rgba(127,191,37,0.42);
            box-shadow: 0 0 0 4px rgba(127,191,37,0.12);
        }
        .nav-search-button {
            flex: 0 0 auto;
            min-height: 44px;
            padding: 0.8rem 1.15rem;
            border: none;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--vintage-green), #5ea51a);
            color: #fff;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            box-shadow: 0 12px 22px rgba(127, 191, 37, 0.18);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .nav-search-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 26px rgba(127, 191, 37, 0.22);
        }
        @media (min-width: 1024px) {
            .nav-topbar {
                display: grid;
                grid-template-columns: auto minmax(0, 1fr);
                align-items: start;
                gap: 1rem 1.5rem;
            }
            .nav-desktop-shell {
                justify-self: end;
                width: min(100%, 58rem);
            }
        }
        .nav-link::after {
            content: '';
            position: absolute;
            left: 0.85rem;
            right: 0.85rem;
            bottom: 0.46rem;
            height: 3px;
            border-radius: 999px;
            background: var(--nav-gradient);
            transform: scaleX(0);
            transform-origin: center;
            transition: transform 0.25s ease;
        }
        .nav-link--home {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), #ffbf52);
            --nav-soft: rgba(246, 163, 24, 0.14);
        }
        .nav-link--actualites {
            --nav-gradient: linear-gradient(135deg, var(--vintage-blue), #1f78d1);
            --nav-soft: rgba(40, 148, 227, 0.14);
        }
        .nav-link--lecture {
            --nav-gradient: linear-gradient(135deg, #7c3f2c, #b66b4c);
            --nav-soft: rgba(124, 63, 44, 0.14);
        }
        .nav-link--agenda {
            --nav-gradient: linear-gradient(135deg, var(--vintage-green), #5ea51a);
            --nav-soft: rgba(127, 191, 37, 0.16);
        }
        .nav-link--about {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            --nav-soft: rgba(246, 163, 24, 0.12);
        }
        .nav-link:hover,
        .nav-link.is-active {
            opacity: 1;
        }
        .nav-link:hover::after,
        .nav-link.is-active::after {
            transform: scaleX(1);
        }
        .nav-link:hover {
            color: var(--ink);
            background: var(--nav-soft);
            transform: translateY(-1px);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.08), 0 10px 18px rgba(22, 49, 74, 0.08);
        }
        .nav-link.is-active {
            color: #fff;
            background: var(--nav-gradient);
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .nav-link.is-active::after {
            background: rgba(255, 255, 255, 0.78);
        }
        .nav-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.08);
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(249,246,242,0.95));
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: var(--ink);
            box-shadow: inset 0 0 0 1px rgba(22, 49, 74, 0.06);
        }
        .nav-toggle[aria-expanded="true"] {
            color: #fff;
            border-color: transparent;
            background: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .mobile-nav-panel {
            padding: 0.75rem 0 1rem;
            border-top: 1px solid var(--line);
        }
        .mobile-nav-search {
            display: grid;
            gap: 0.7rem;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--line);
        }
        .mobile-nav-search-row {
            display: grid;
            gap: 0.75rem;
        }
        @media (min-width: 560px) {
            .mobile-nav-search-row {
                grid-template-columns: minmax(0, 1fr) auto;
                align-items: center;
            }
        }
        .mobile-nav-search-input {
            width: 100%;
            min-height: 48px;
            padding: 0.85rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.12);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.96);
            color: var(--ink);
            outline: none;
        }
        .mobile-nav-search-input::placeholder {
            color: #7b8a9a;
        }
        .mobile-nav-search-input:focus {
            border-color: rgba(127,191,37,0.42);
            box-shadow: 0 0 0 4px rgba(127,191,37,0.12);
        }
        .mobile-nav-search-button {
            min-height: 48px;
            padding: 0.85rem 1.15rem;
            border: none;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--vintage-green), #5ea51a);
            color: #fff;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            box-shadow: 0 12px 22px rgba(127, 191, 37, 0.18);
        }
        .mobile-nav-link {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 0.55rem;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(22, 49, 74, 0.08);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.94);
            font-family: 'Sora', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--ink);
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
        }
        .mobile-nav-link::before {
            content: '';
            flex: 0 0 auto;
            width: 0.72rem;
            height: 0.72rem;
            border-radius: 999px;
            background: var(--nav-gradient);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
        }
        .mobile-nav-link--home {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), #ffbf52);
        }
        .mobile-nav-link--actualites {
            --nav-gradient: linear-gradient(135deg, var(--vintage-blue), #1f78d1);
        }
        .mobile-nav-link--lecture {
            --nav-gradient: linear-gradient(135deg, #7c3f2c, #b66b4c);
        }
        .mobile-nav-link--agenda {
            --nav-gradient: linear-gradient(135deg, var(--vintage-green), #5ea51a);
        }
        .mobile-nav-link--about {
            --nav-gradient: linear-gradient(135deg, var(--vintage-red), var(--vintage-blue));
        }
        .mobile-nav-link:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(22, 49, 74, 0.08);
        }
        .mobile-nav-link.is-active {
            color: #fff;
            border-color: transparent;
            background: var(--nav-gradient);
            box-shadow: 0 14px 24px rgba(22, 49, 74, 0.14);
        }
        .mobile-nav-link.is-active::before {
            background: rgba(255, 255, 255, 0.88);
            box-shadow: none;
        }
        .section-shell {
            position: relative;
            overflow: hidden;
            padding: 1.4rem;
            border: 1px solid var(--line);
            border-radius: var(--radius-xl);
            background: rgba(255, 255, 255, 0.94);
            box-shadow: var(--shadow-card);
        }
        @media (min-width: 768px) {
            .section-shell {
                padding: 1.75rem;
            }
        }
        .section-shell::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.34), transparent 14%);
            pointer-events: none;
        }
        .section-header {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
            margin-bottom: 1.8rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--line);
        }
        .section-kicker {
            font-size: 0.72rem;
            letter-spacing: 0.24em;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--vintage-blue);
        }
        .paper-card {
            border: 1px solid var(--line);
            border-radius: 18px;
            background: rgba(255,255,255,0.96);
            box-shadow: 0 10px 20px rgba(31, 31, 28, 0.05);
        }
        .category-chip {
            display: inline-flex;
            align-items: center;
            padding: 0.28rem 0.75rem;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255,255,255,0.94);
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }
