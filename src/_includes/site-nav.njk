<nav class="sticky top-0 z-50 glass-nav border-b border-ink/10" data-site-nav>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-20 items-center gap-4">
            <a href="index.html" class="flex-shrink-0 flex items-center gap-3 font-heading font-bold text-2xl tracking-tight">
                <span class="flex items-center justify-center w-11 h-11 rounded-xl text-white text-lg shadow-lg shadow-sky-200/70" style="background: linear-gradient(135deg, var(--vintage-red), var(--vintage-green) 48%, var(--vintage-blue));">✦</span>
                <div>
                    <div>Le Bulletin</div>
                    <div class="text-[10px] uppercase tracking-[0.28em] text-vintage-red font-body">Annet-sur-Marne</div>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-8 font-heading font-bold uppercase tracking-widest text-xs">
                {% for item in journal.site.navigation %}
                <a
                    href="{{ item.href }}"
                    class="nav-link nav-link--{{ item.key }}{% if activePage == item.key %} is-active{% endif %}"
                    data-nav-key="{{ item.key }}"
                    {% if item.rubrique %}data-nav-rubrique="{{ item.rubrique }}"{% endif %}
                    {% if activePage == item.key %}aria-current="page"{% endif %}
                >{{ item.label }}</a>
                {% endfor %}
            </div>

            <button
                type="button"
                class="nav-toggle md:hidden"
                data-nav-toggle
                aria-expanded="false"
                aria-controls="site-mobile-nav"
            >
                Menu
            </button>
        </div>

        <div id="site-mobile-nav" class="mobile-nav-panel hidden md:hidden" data-nav-panel>
            {% for item in journal.site.navigation %}
            <a
                href="{{ item.href }}"
                class="mobile-nav-link mobile-nav-link--{{ item.key }}{% if activePage == item.key %} is-active{% endif %}"
                data-nav-key="{{ item.key }}"
                {% if item.rubrique %}data-nav-rubrique="{{ item.rubrique }}"{% endif %}
                {% if activePage == item.key %}aria-current="page"{% endif %}
            >{{ item.label }}</a>
            {% endfor %}
        </div>
    </div>
</nav>

<script>
    (() => {
        const navRoot = document.querySelector('[data-site-nav]');
        if (!navRoot) {
            return;
        }

        const toggle = navRoot.querySelector('[data-nav-toggle]');
        const panel = navRoot.querySelector('[data-nav-panel]');

        if (!toggle || !panel) {
            return;
        }

        toggle.addEventListener('click', () => {
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', String(!isExpanded));
            panel.classList.toggle('hidden', isExpanded);
        });

        panel.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => {
                toggle.setAttribute('aria-expanded', 'false');
                panel.classList.add('hidden');
            });
        });

        const currentUrl = new URL(window.location.href);
        const rubrique = currentUrl.searchParams.get('rubrique');
        const lectureLinks = navRoot.querySelectorAll('[data-nav-key="lecture"]');
        const actualitesLinks = navRoot.querySelectorAll('[data-nav-key="actualites"]');

        if (rubrique === 'Coup de cœur littéraire' && /portail\.html$/.test(currentUrl.pathname)) {
            actualitesLinks.forEach((link) => {
                link.classList.remove('is-active');
                link.removeAttribute('aria-current');
            });

            lectureLinks.forEach((link) => {
                link.classList.add('is-active');
                link.setAttribute('aria-current', 'page');
            });
        }
    })();
</script>
